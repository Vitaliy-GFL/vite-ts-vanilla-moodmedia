{
  "$schema": "https://raw.githubusercontent.com/nicolo-ribaudo/oxc/json-schema/npm/oxlint/configuration_schema.json",
  "plugins": ["react", "typescript"],
  "rules": {
    "no-unused-vars": "warn",
    "react/exhaustive-deps": "warn",
    "react/rules-of-hooks": "error"
  },
  "ignorePatterns": ["dist"]
}
