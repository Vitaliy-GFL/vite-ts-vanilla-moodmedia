{
  "name": "vite-react-ts-moodmedia-ai",
  "private": true,
  "version": "1.0.0",
  "type": "module",
  "scripts": {
    "dev": "vite",
    "lint": "oxlint .",
    "fmt": "oxfmt -c .oxfmtrc.json src/",
    "fmt:check": "oxfmt -c .oxfmtrc.json --check src/",
    "preview": "vite preview",
    "build": "npm run lint && npm run fmt:check && tsc -b && vite build && node scripts/compile.mjs",
    "build:simple": "tsc -b && vite build",
    "compile": "node scripts/compile.mjs"
  },
  "dependencies": {
    "mtemplate-loader": "^2.0.40",
    "react": "^19.2.5",
    "react-dom": "^19.2.5",
    "zustand": "^5.0.12"
  },
  "devDependencies": {
    "@types/node": "^22.3.0",
    "@types/react": "^19.2.14",
    "@types/react-dom": "^19.2.3",
    "@vitejs/plugin-legacy": "^8.0.1",
    "@vitejs/plugin-react": "^6.0.1",
    "mtemplate": "^1.0.7",
    "oxlint": "^1.0.0",
    "oxfmt": "^0.42.0",
    "sass": "^1.77.8",
    "typescript": "^6.0.3",
    "vite": "^8.0.10"
  }
}
